<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <view class="user-avatar">
      <open-data type="userAvatarUrl"></open-data>
    </view>
    <view class="user-info">
      <view class="user-name">
        <open-data type="userNickName"></open-data>
      </view>
      <view class="user-status">
        <view class="member-badge" wx:if="{{isMember}}">会员</view>
        <view class="free-badge" wx:else>免费用户</view>
      </view>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stats-item">
      <view class="stats-num">{{totalGenerated}}</view>
      <view class="stats-label">累计生成</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <view class="stats-num">{{todayGenerated}}</view>
      <view class="stats-label">今日生成</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <view class="stats-num">{{favoriteCount}}</view>
      <view class="stats-label">收藏话术</view>
    </view>
  </view>

  <!-- 会员推广 -->
  <view class="member-banner" wx:if="{{!isMember}}" bindtap="goToMember">
    <view class="member-content">
      <view class="member-title">升级会员，畅享无限</view>
      <view class="member-desc">9.9 元/月，无限次生成 + 高级模板</view>
    </view>
    <view class="member-btn">立即开通</view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToFavorites">
      <view class="menu-icon">⭐</view>
      <view class="menu-text">我的收藏</view>
      <view class="menu-arrow">></view>
    </view>
    <view class="menu-item" bindtap="goToHelp">
      <view class="menu-icon">❓</view>
      <view class="menu-text">使用帮助</view>
      <view class="menu-arrow">></view>
    </view>
    <view class="menu-item" bindtap="goToFeedback">
      <view class="menu-icon">💬</view>
      <view class="menu-text">意见反馈</view>
      <view class="menu-arrow">></view>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <view class="menu-icon">ℹ️</view>
      <view class="menu-text">关于我们</view>
      <view class="menu-arrow">></view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">版本 v1.0.0</view>
</view>
