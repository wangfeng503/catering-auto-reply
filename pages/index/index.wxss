.container {
  padding: 16px;
  padding-bottom: 32px;
}

/* 顶部横幅 */
.header-banner {
  background: linear-gradient(135deg, #c45c3e, #d4735a);
  border-radius: 16px;
  padding: 24px 20px;
  margin-bottom: 16px;
  color: #fff;
}

.header-title {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 6px;
}

.header-subtitle {
  font-size: 14px;
  opacity: 0.9;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px 16px;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-num {
  font-size: 28px;
  font-weight: 700;
  color: #c45c3e;
  margin-bottom: 4px;
}

.stats-label {
  font-size: 12px;
  color: #999;
}

.stats-divider {
  width: 1px;
  height: 40px;
  background: #e8e8e8;
}

/* 快捷入口 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-bottom: 16px;
}

.action-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px 12px;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.action-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.action-title {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 4px;
}

.action-desc {
  font-size: 11px;
  color: #999;
}

/* 使用引导 */
.guide-section {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.guide-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 16px;
  text-align: center;
}

.guide-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.guide-step {
  text-align: center;
}

.step-num {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, #c45c3e, #d4735a);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  margin: 0 auto 6px;
}

.step-text {
  font-size: 12px;
  color: #666;
}

.step-arrow {
  font-size: 20px;
  color: #c45c3e;
  margin: 0 12px;
  padding-bottom: 20px;
}

.guide-close {
  text-align: center;
  color: #c45c3e;
  font-size: 14px;
  padding: 8px;
}

/* 会员推广 */
.member-banner {
  background: linear-gradient(135deg, #2d6a4f, #40916c);
  border-radius: 12px;
  padding: 16px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
  color: #fff;
}

.member-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 4px;
}

.member-desc {
  font-size: 12px;
  opacity: 0.9;
}

.member-btn {
  background: #fff;
  color: #2d6a4f;
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
}

/* 最近生成 */
.recent-section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
}

.section-more {
  font-size: 13px;
  color: #c45c3e;
}

.recent-item {
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-review {
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recent-reply {
  font-size: 14px;
  color: #1a1a1a;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recent-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recent-type {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 10px;
}

.recent-type.好评 {
  background: #e8f5e9;
  color: #2d6a4f;
}

.recent-type.中评 {
  background: #fff3e0;
  color: #e65100;
}

.recent-type.差评 {
  background: #ffebee;
  color: #c62828;
}

.recent-time {
  font-size: 11px;
  color: #999;
}
