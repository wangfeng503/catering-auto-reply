.container {
  padding: 16px;
  padding-bottom: 32px;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}

.filter-item {
  padding: 6px 16px;
  background: #f0eeeb;
  border-radius: 20px;
  font-size: 13px;
  color: #666;
}

.filter-item.active {
  background: linear-gradient(135deg, #c45c3e, #d4735a);
  color: #fff;
}

/* 搜索框 */
.search-bar {
  margin-bottom: 16px;
}

.search-input {
  background: #f5f5f5;
  border-radius: 8px;
  padding: 10px 16px;
  font-size: 14px;
  width: 100%;
  box-sizing: border-box;
}

/* 历史列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.history-item {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.item-type {
  font-size: 12px;
  padding: 2px 10px;
  border-radius: 10px;
  font-weight: 600;
}

.item-type.good {
  background: #e8f5e9;
  color: #2d6a4f;
}

.item-type.medium {
  background: #fff3e0;
  color: #e65100;
}

.item-type.bad {
  background: #ffebee;
  color: #c62828;
}

.item-time {
  font-size: 12px;
  color: #999;
}

.item-review {
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-reply {
  font-size: 14px;
  color: #1a1a1a;
  line-height: 1.6;
  margin-bottom: 10px;
  padding: 10px;
  background: #f8f6f3;
  border-radius: 8px;
}

.item-meta {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.meta-tag {
  font-size: 11px;
  padding: 2px 8px;
  background: #f0eeeb;
  border-radius: 8px;
  color: #666;
}

.item-actions {
  display: flex;
  gap: 12px;
}

.action-btn {
  font-size: 13px;
  color: #c45c3e;
  padding: 4px 12px;
}

.action-btn.delete {
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  color: #666;
  margin-bottom: 8px;
}

.empty-sub {
  font-size: 13px;
  color: #999;
  margin-bottom: 24px;
}

.btn-primary {
  background: linear-gradient(135deg, #c45c3e, #d4735a);
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 12px 32px;
  font-size: 15px;
  font-weight: 600;
}
